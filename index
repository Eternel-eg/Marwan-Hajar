<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wedding Invitation - Marwan & Hajar</title>
    
    <link rel="icon" href="https://drive.google.com/thumbnail?id=1A9ZVt5Fbh-r2aRnb79-x_6Fj10YVQ4O8&sz=s800">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&family=Cinzel:wght@400..900&family=Lato:wght@300;400;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Tajawal:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --color-gold: #D4AF37; 
            --color-navy: #1B263B;
            --color-cream: #FDFBF7;
        }

        /* Enforce 9:16 Aspect Ratio on Body/Wrapper */
        body {
            font-family: 'Lato', sans-serif;
            background-color: #1a1a1a; /* Dark background for desktop spaces */
            color: var(--color-navy);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        #mobile-container {
            width: 100vw;
            height: calc(100vw * 16 / 9);
            max-height: 100vh;
            max-width: calc(100vh * 9 / 16);
            position: relative;
            overflow: hidden;
            background-color: var(--color-cream);
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }

        /* --- PRELOADER --- */
        #preloader {
            position: absolute; /* Changed to absolute to stay inside container */
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: var(--color-navy);
            z-index: 100;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: opacity 0.8s ease-out, visibility 0.8s;
        }
        
        .loader-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(212, 175, 55, 0.3);
            border-radius: 50%;
            border-top-color: var(--color-gold);
            animation: spin 1s ease-in-out infinite;
            margin-bottom: 15px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* --- Typography Classes --- */
        .font-playfair { font-family: 'Playfair Display', serif; }
        .font-cinzel { font-family: 'Cinzel', serif; }
        .font-dancing-script { font-family: 'Dancing Script', cursive; }
        .font-tajawal { font-family: 'Tajawal', sans-serif; }

        .text-gold { color: var(--color-gold); }
        .bg-gold { background-color: var(--color-gold); }
        .border-gold { border-color: var(--color-gold); }

        /* --- Page 1 (Entry) - Door Animation Styles --- */
        #page1 {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 50; 
            perspective: 1500px;
            overflow: hidden;
            pointer-events: auto;
            transition: pointer-events 0s linear 1.5s;
        }
        
        .show-page2 #page1 {
            pointer-events: none;
        }

        .door {
            position: absolute;
            top: 0;
            width: 50.2%; 
            height: 100%;
            overflow: hidden; 
            transition: transform 2.5s cubic-bezier(0.4, 0.0, 0.2, 1);
            transform-style: preserve-3d;
            z-index: 10;
            background-color: var(--color-navy);
        }

        .door-inner {
            position: absolute;
            top: 0;
            width: 200%; 
            height: 100%;
            background-color: var(--color-navy); 
            background-image: url('https://drive.google.com/thumbnail?id=1f_g428ADuRxSe5HIzT5BPZUZHpEMdbeX&sz=w1920');
            background-size: cover; 
            background-position: center; 
            pointer-events: none;
        }

        .door-left { left: 0; transform-origin: left center; }
        .door-left .door-inner { left: 0; }
        .door-right { right: 0; transform-origin: right center; }
        .door-right .door-inner { left: -100%; }

        .door::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.2); 
            z-index: 2; 
        }

        .show-page2 .door-left { transform: rotateY(-110deg); }
        .show-page2 .door-right { transform: rotateY(110deg); }

        #invitation-overlay {
            transition: opacity 1s ease 0.2s;
            opacity: 1;
        }
        .show-page2 #invitation-overlay {
            opacity: 0;
            pointer-events: none;
        }

        /* --- Page 2 (Details) --- */
        #page2 {
            position: absolute;
            inset: 0;
            z-index: 20; 
            background: radial-gradient(circle at 50% 50%, #FDFBF7 0%, #f4f1ea 100%);
            overflow-y: auto;
            overflow-x: hidden;
            scroll-smooth: true;
            visibility: hidden; 
            opacity: 0;
            transition: opacity 1s ease-in;
        }
        
        .show-page2 #page2 {
            visibility: visible;
            opacity: 1;
        }

        /* Scrollbar styling for page2 inside container */
        #page2::-webkit-scrollbar { width: 6px; }
        #page2::-webkit-scrollbar-track { background: #FDFBF7; }
        #page2::-webkit-scrollbar-thumb { background: #D4AF37; border-radius: 4px; }

        /* --- Scroll Reveal Animations --- */
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1s ease-out, transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .stagger-1 { transition-delay: 100ms; }
        .stagger-2 { transition-delay: 200ms; }

        /* --- Floating Particles Canvas --- */
        #particles-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 60; 
            pointer-events: none;
        }
        .show-page2 #particles-canvas { opacity: 0; transition: opacity 1s; }

        /* --- Custom Button --- */
        .btn-royal {
            background: linear-gradient(135deg, #1B263B 0%, #304a6e 100%);
            color: #D4AF37;
            border: 1px solid #D4AF37;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 50; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }
        .btn-royal::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.4), transparent);
            transition: left 0.6s ease;
            z-index: -1;
        }
        .btn-royal:hover::before { left: 100%; }
        .btn-royal:hover {
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.5);
            transform: translateY(-3px) scale(1.05);
            color: white;
            border-color: white;
        }

        /* --- Gallery --- */
        .gallery-item {
            overflow: hidden;
            border-radius: 4px;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }
        .gallery-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            z-index: 10;
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .gallery-item:hover img { transform: scale(1.15); }

        /* Pulse for countdown */
        @keyframes pulse-soft {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(0.95); opacity: 0.9; }
        }
        .animate-pulse-soft { animation: pulse-soft 2s infinite ease-in-out; }
        
        .eternel-copyright {
            font-family: 'Cinzel', serif;
            letter-spacing: 2px;
            font-size: 9px;
            margin-top: 15px;
            display: block;
            color: #D4AF37;
            opacity: 0.8;
        }
    </style>
</head>
